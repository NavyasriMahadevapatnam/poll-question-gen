{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ESNext"],
    "outDir": "build",
    "rootDir": "src", // Changed back to "." to include scripts directory
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "sourceRoot": "./src",
    "resolveJsonModule": true,
    "allowArbitraryExtensions": false,
    "incremental": true,
    "paths": {
      "#root/*": ["./src/*"],
      "#core/*": ["./src/core/*"],
      "#infrastructure/*": ["./src/infrastructure/*"],
      "#shared/*": ["./src/shared/*"],
      "#auth/*": ["./src/modules/auth/*"],
      "#genai/*": ["./src/modules/genai/*"],
      "#users/*": ["./src/modules/users/*"],
      "#livequizzes/*": ["./src/modules/livequizzes/*"]
    },
    "types": ["node", "express", "routing-controllers", "routing-controllers-openapi"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "exclude": ["build", "dist", "node_modules", "**/*.spec.ts", "**/*.d.ts", "vite.config.ts"]
}
